{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "HI拿智能派样",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/info/index",
      "style": {
        "navigationBarTitleText": "领取礼品",
        "navigationStyle": "custom",
        "disableScroll": true
      }
    },
    {
      "path": "pages/code/index",
      "style": {
        "navigationBarTitleText": "兑换码",
        "navigationBarBackgroundColor": "#667eea",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/mycode/index",
      "style": {
        "navigationBarTitleText": "我的兑换码",
        "navigationBarBackgroundColor": "#667eea",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "HI拿派样",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#667eea",
    "borderStyle": "black",
    "backgroundColor": "#ffffff"
  },
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
    }
  }
}
