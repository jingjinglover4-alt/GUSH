# 硬件网关环境变量示例

# 服务器配置
SECRET_KEY=your-secret-key-here
HOST=0.0.0.0
PORT=5003
DEBUG=False

# WebSocket配置
SOCKETIO_PING_TIMEOUT=30
SOCKETIO_PING_INTERVAL=25
SOCKETIO_ASYNC_MODE=eventlet

# Redis配置（用于连接管理和消息队列）
REDIS_URL=redis://localhost:6379/0

# 数据库配置（连接现有管理后台数据库）
DATABASE_URI=sqlite:////opt/hinana-admin/instance/hinana.db

# 安全配置
TOKEN_SECRET=your-hardware-token-secret
TOKEN_EXPIRE_DAYS=365

# 硬件认证白名单（逗号分隔的IMEI前缀）
ALLOWED_IMEI_PREFIXES=86570904

# 速率限制
RATE_LIMIT_PER_MINUTE=60

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/var/log/hardware-gateway.log